{
  "name": "smshive",
  "version": "1.0.0",
  "private": true,
  "description": "SMSHIVE — Turn your Android into a professional SMS gateway. Free. Forever. No limits.",
  "workspaces": [
    "web/*",
    "app/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "dev:web": "npm run dev -w web/dashboard",
    "dev:api": "npm run start:dev -w web/api",
    "build": "npm run build --workspaces --if-present",
    "build:web": "npm run build -w web/dashboard",
    "build:api": "npm run build -w web/api",
    "start": "concurrently \"npm run start:api\" \"npm run start:web\"",
    "start:prod": "concurrently -k \"node server/proxy.js\" \"npm run start:prod -w web/api\" \"npm start -w web/dashboard -- --port 3001\"",
    "start:api": "npm run start:prod -w web/api",
    "start:web": "npm run start -w web/dashboard",
    "lint": "npm run lint --workspaces --if-present",
    "clean": "rimraf node_modules web/*/node_modules app/*/node_modules"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "optionalDependencies": {
    "@tailwindcss/oxide-linux-arm64-gnu": "4.3.0",
    "@tailwindcss/oxide-linux-x64-gnu": "4.3.0",
    "lightningcss-linux-arm64-gnu": "1.32.0",
    "lightningcss-linux-x64-gnu": "1.32.0"
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "http-proxy": "^1.18.1"
  }
}
